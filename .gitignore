# ==========================================
# 1. 安全与机密文件 (⚠️ 极其重要)
# ==========================================
.env
.env.local
.env.*

# ==========================================
# 2. 本地缓存与下载的本子数据 (防大文件撑爆Git)
# ==========================================
local_downloads/
downloads/
*.cbz
*.zip
*.epub
*.pdf

# ==========================================
# 3. 日志文件
# ==========================================
*.log
bot.log

# ==========================================
# 4. Python 运行缓存与虚拟环境
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# ==========================================
# 5. IDE 配置 (PyCharm / VSCode)
# ==========================================
.idea/
.vscode/
*.swp
*.swo

# ==========================================
# 6. 操作系统缓存文件 (Windows / Mac)
# ==========================================
Thumbs.db
desktop.ini
.DS_Store